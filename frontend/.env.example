# Leave empty in development to use Vite proxy to the API (see vite.config.ts).
# For production or mobile testing against a remote API, set the full origin:
# VITE_API_URL=https://api.example.com

# Socket.IO server (defaults to http://localhost:8080 in dev via src/lib/env.ts)
# VITE_SOCKET_URL=http://localhost:8080
